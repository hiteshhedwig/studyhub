{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "Study Hub",
    "version": "0.1.25"
  },
  "build": {
    "beforeDevCommand": "npm run dev -- --port 5199",
    "devPath": "http://127.0.0.1:5199",
    "beforeBuildCommand": "npm run build",
    "distDir": "../dist"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "dialog": {
        "all": true
      },
      "fs": {
        "all": true,
        "scope": ["**"]
      },
      "notification": {
        "all": true
      },
      "window": {
        "all": true
      },
      "shell": {
        "open": "^(https?://|mailto:|tel:|file://|/|[A-Za-z]:[\\\\/]).*"
      }
    },
    "windows": [
      {
        "title": "Study Hub",
        "width": 1280,
        "height": 840,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.local.studyhub",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ]
    }
  }
}
